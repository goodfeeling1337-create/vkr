# Copy to .env and adjust
SECRET_KEY=dev-secret-change-in-production

# PostgreSQL (обязательно). Формат: postgresql+psycopg://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql+psycopg://dn_user:dn_pass@localhost:5432/dn_db

UPLOAD_DIR=./uploads
SESSION_COOKIE_NAME=dn_session
SESSION_MAX_AGE=86400
LOG_LEVEL=INFO
DEFAULT_SCORING_MODE=training
ALLOW_OPTIONAL_PURE_JUNCTION_RELATIONS=true
