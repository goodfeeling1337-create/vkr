# Скопируйте в .env и при необходимости поправьте:
#   cp .env.example .env
#
# Pydantic читает этот файл из корня проекта (см. app/core/config.py).

# --- Безопасность и сессии ---
# Секрет подписи cookie сессии; в продакшене задайте длинную случайную строку.
SECRET_KEY=dev-secret-change-me
# development | production
APP_ENVIRONMENT=development
# При HTTPS в production: true
SESSION_COOKIE_SECURE=false

# --- База данных (обязательно для запуска) ---
# Формат SQLAlchemy + psycopg v3:
#   postgresql+psycopg://USER:PASSWORD@HOST:PORT/DATABASE
# Локально (PostgreSQL на этой машине), пользователь/БД как в docker-compose:
DATABASE_URL=postgresql+psycopg://dn_user:dn_pass@localhost:5432/dn_db

# --- Файлы ---
# Каталог для загружаемых .xlsx (создайте: mkdir -p uploads)
UPLOAD_DIR=./uploads

# --- Cookie сессии ---
SESSION_COOKIE_NAME=dn_session
# Время жизни cookie в секундах (по умолчанию в коде — 7 суток: 604800)
SESSION_MAX_AGE=604800

# --- Прочее ---
LOG_LEVEL=INFO

# Режим оценивания эталона: training | testing
DEFAULT_SCORING_MODE=training

# Учитывать ли опциональные «чистые» связующие отношения (см. доменную логику варианта)
ALLOW_OPTIONAL_PURE_JUNCTION_RELATIONS=true
